PORT=4000

# Qwen / DashScope (OpenAI-compatible). Use the *intl* endpoint outside mainland China.
DASHSCOPE_API_KEY=sk-...

# Pick one model — comment/uncomment to swap.
QWEN_MODEL=qwen-turbo    # fastest, cheapest (default)
# QWEN_MODEL=qwen-plus   # balanced cost / reasoning
# QWEN_MODEL=qwen-max    # strongest, slowest, most expensive

# Persistence mode.
#   unset / "development" → local SQLite at SQLITE_PATH (default ./qwen.sqlite).
#   "production"          → Aliyun ApsaraDB / PolarDB via DATABASE_URL below.
NODE_ENV=development
SQLITE_PATH=./qwen.sqlite

# ApsaraDB RDS / PolarDB (standard Postgres over TCP). Required when NODE_ENV=production.
DATABASE_URL=postgres://user:pass@host:5432/qwen_data_wrangler
